# Copy to .env.local and fill in real values. Never commit .env.local.
# These live on the server only (Vercel project env vars) — never expose
# secrets to the browser.

# AI Gateway auth uses Vercel-managed OIDC — no API key needed. Locally,
# `vercel env pull` fetches a VERCEL_OIDC_TOKEN; on Vercel it's automatic.

# "fake" | "real"; overridden by Edge Config aiMode. Default fake.
AI_MODE=

# Vercel Edge Config connection string (for aiMode / freeDailyInputs)
EDGE_CONFIG=

# Auth is faked and passwordless (PRODUCT §12): guest/sign-in is a client-side
# profile keyed by email-or-name, no credentials or server-side auth exist.
