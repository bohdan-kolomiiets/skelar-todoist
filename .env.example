# Copy to .env.local and fill in real values. Never commit .env.local.
# These live on the server only (Vercel project env vars) — never expose
# an AI API key to the browser.

# AI provider key used by the server-side route that parses brain-dump
# text into structured tasks.
AI_API_KEY=

